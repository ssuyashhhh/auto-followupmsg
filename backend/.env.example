# ============================================
# App
# ============================================
APP_NAME=Auto Follow-Ups
DEBUG=true
API_PREFIX=/api/v1

# ============================================
# Database
# ============================================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/auto_followups

# ============================================
# Redis
# ============================================
REDIS_URL=redis://localhost:6379/0

# ============================================
# Supabase
# ============================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_BUCKET=uploads

# ============================================
# AI Keys
# ============================================
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
DEFAULT_AI_MODEL=gpt-4

# ============================================
# Auth
# ============================================
SECRET_KEY=change-me-to-a-random-64-char-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================
# Frontend (CORS)
# ============================================
FRONTEND_URL=https://your-app.vercel.app

# ============================================
# File Upload
# ============================================
MAX_FILE_SIZE_MB=10

# ============================================
# PRODUCTION NOTES
# ============================================
# Supabase DB:  Dashboard → Settings → Database → Connection string (URI)
#   Replace "postgres://" with "postgresql+asyncpg://"
#   Use port 6543 (connection pooler) for better performance
# Upstash Redis: Console → Your DB → Details → redis:// endpoint
# Generate SECRET_KEY: python -c "import secrets; print(secrets.token_urlsafe(64))"
